<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/dialog_speciality.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog"
    android:paddingBottom="8dp">

    <!-- En-tête du dialog -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:background="@drawable/bg_dialog_header">

        <!-- Barre bleue déco -->
        <View
            android:layout_width="4dp"
            android:layout_height="24dp"
            android:background="@drawable/bg_toggle_selected"
            android:layout_marginRight="10dp" />

        <TextView
            android:id="@+id/tvDialogTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Choose Your Speciality"
            android:textColor="#1A2B3C"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Séparateur -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEF3F8" />

    <!-- Liste des spécialités -->
    <LinearLayout
        android:id="@+id/specialityContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" />

    <!-- Séparateur -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEF3F8"
        android:layout_marginTop="8dp" />

    <!-- Bouton annuler -->
    <TextView
        android:id="@+id/tvDialogCancel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:text="Cancel"
        android:textColor="#8A96A3"
        android:textSize="13sp"
        android:clickable="true"
        android:focusable="true" />

</LinearLayout>