<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/activity_create_project.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4F8">

    <!-- ===== HEADER ===== -->

    <!-- ===== FORMULAIRE SCROLLABLE ===== -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@drawable/bg_header_gradient"
        android:gravity="center_vertical"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="24dp">

        <!-- Bouton retour -->

        <!-- Titre -->
        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:text="←"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Create New Project"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold" />

    </RelativeLayout>

    <!-- ===== FOOTER BOUTONS ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Project Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Project Title"
                android:textColor="#1A2B3C"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etTitle"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_input"
                android:hint="Enter project title"
                android:inputType="text"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:textColor="#1A2B3C"
                android:textColorHint="#8A96A3"
                android:textSize="13sp" />

            <!-- Description -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Description"
                android:textColor="#1A2B3C"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_input"
                android:gravity="top"
                android:hint="Enter project description"
                android:inputType="textMultiLine"
                android:paddingLeft="14dp"
                android:paddingTop="12dp"
                android:paddingRight="14dp"
                android:textColor="#1A2B3C"
                android:textColorHint="#8A96A3"
                android:textSize="13sp" />

            <!-- Max Students -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Max Students"
                android:textColor="#1A2B3C"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etMaxStudents"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_input"
                android:hint="e.g. 5"
                android:inputType="number"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:textColor="#1A2B3C"
                android:textColorHint="#8A96A3"
                android:textSize="13sp" />

            <!-- Required Points -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Required Points"
                android:textColor="#1A2B3C"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etRequiredPoints"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_input"
                android:hint="e.g. 100"
                android:inputType="number"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:textColor="#1A2B3C"
                android:textColorHint="#8A96A3"
                android:textSize="13sp" />

            <!-- Add Skills -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add Skills"
                android:textColor="#1A2B3C"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- Liste dynamique des skills -->
            <LinearLayout
                android:id="@+id/skillsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:orientation="vertical"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

            <!-- Bouton Add Skill -->
            <Button
                android:id="@+id/btnAddSkill"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_btn_dashed"
                android:stateListAnimator="@null"
                android:text="＋  Add Skill"
                android:textColor="#2E86DE"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:paddingLeft="18dp"
        android:paddingRight="18dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:background="#F0F4F8"
        android:elevation="4dp">

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="CANCEL"
            android:textColor="#2E86DE"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/bg_btn_cancel"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btnCreateProject"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.8"
            android:layout_marginLeft="10dp"
            android:text="CREATE PROJECT"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/bg_btn_login"
            android:stateListAnimator="@null" />

    </LinearLayout>

</LinearLayout>